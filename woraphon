          <div className="bg-white/95 rounded-[3.5rem] p-8 md:p-12 shadow-2xl flex-1 space-y-8 overflow-y-auto no-scrollbar">
              {portfolioData.certificates.map((cert, index) => (
                  <div key={cert.id} className="relative bg-gradient-to-r from-slate-50 to-white border-2 border-slate-100 p-8 rounded-[2.5rem] shadow-sm hover:shadow-md transition-all group overflow-hidden">
                      <div className="absolute top-0 right-0 w-32 h-32 bg-indigo-500/5 rounded-full -mr-16 -mt-16 group-hover:scale-110 transition-transform"></div>
                      <div className="flex flex-col md:flex-row gap-8 items-start relative z-10">
                          <div className="bg-indigo-600 p-6 rounded-3xl text-white shadow-xl shadow-indigo-200">
                              <Medal size={48} />
                          </div>
                          <div className="flex-1 space-y-3">
                              <div className="flex flex-wrap items-center gap-3">
                                  <span className="bg-yellow-400 text-yellow-900 text-xs font-black px-3 py-1 rounded-full uppercase tracking-widest">{cert.award}</span>
                                  <span className="text-slate-400 text-xs font-bold uppercase tracking-widest">{cert.year}</span>
                              </div>
                              <h3 className="text-2xl font-black text-slate-800 leading-tight">{cert.title}</h3>
                              <p className="text-slate-600 leading-relaxed text-sm italic">{cert.desc}</p>
                          </div>
                      </div>
                  </div>
              ))}
          </div>
      </div>
    );

    // --- กิจกรรม ---
    if (pId === 'p6' || pId === 'p7') return (
        <div className="h-full flex flex-col space-y-8 animate-in fade-in">
             <h2 className="text-5xl font-black text-white font-kanit flex items-center gap-4"><Calendar size={48}/> ACTIVITIES</h2>
             <div className="bg-white/95 rounded-[3.5rem] p-10 shadow-2xl flex-1 grid grid-cols-1 md:grid-cols-2 gap-8 overflow-y-auto no-scrollbar">
                {portfolioData.activities.map((act, index) => (
                    <div key={act.id} className="bg-slate-50 rounded-[2.5rem] overflow-hidden flex flex-col border border-slate-100 hover:shadow-lg transition-all">
                        <div className="h-48 relative group">
                            <img src={act.img} className="w-full h-full object-cover" alt={act.title} />
                        </div>
                        <div className="p-6 space-y-2">
                            <div className="bg-indigo-100 text-indigo-600 w-fit px-3 py-1 rounded-full text-xs font-black uppercase">Project {index + 1}</div>
                            <h4 className="font-bold text-xl text-slate-800">{act.title}</h4>
                            <p className="text-sm text-slate-500 leading-relaxed">{act.desc}</p>
                        </div>
                    </div>
                ))}
             </div>
        </div>
    );

    return (
        <div className="h-full flex flex-col space-y-8 animate-in fade-in">
             <h2 className="text-5xl font-black text-white font-kanit flex items-center gap-4">{pages[currentPage].icon} {pages[currentPage].title}</h2>
             <div className="bg-white/95 rounded-[3.5rem] p-12 shadow-2xl flex-1 overflow-y-auto no-scrollbar flex flex-col items-center justify-center text-center">
                <div className="bg-slate-100 p-12 rounded-full text-slate-200 mb-6">
                    <FileText size={80} />
                </div>
                <p className="text-2xl text-slate-400 font-bold">ข้อมูลส่วนนี้จะถูกเพิ่มเติมในลำดับถัดไป</p>
             </div>
        </div>
    );
  };

  return (
    <div className="min-h-screen bg-[#f1f5f9] flex overflow-hidden">
      <input type="file" ref={fileInputRef} onChange={handleFileChange} accept="image/*" className="hidden" />

      {/* Navigation Sidebar */}
      <div className="w-20 md:w-28 bg-white border-r border-slate-100 flex flex-col items-center py-8 space-y-6 z-50">
        <div className="w-12 h-12 md:w-16 md:h-16 bg-indigo-600 rounded-2xl flex items-center justify-center text-white font-black text-xl shadow-lg">TCAS</div>
        <div className="flex-1 space-y-4 overflow-y-auto no-scrollbar px-2">
          {pages.map((p, i) => (
            <button key={p.id} onClick={() => setCurrentPage(i)} className={`w-12 h-12 md:w-16 md:h-16 rounded-2xl flex items-center justify-center transition-all ${currentPage === i ? 'bg-indigo-600 text-white shadow-xl' : 'text-slate-300 hover:bg-slate-50'}`}>
              {p.icon}
            </button>
          ))}
        </div>
        <button onClick={() => isAdmin ? setIsEditing(!isEditing) : setShowAuth(true)} className={`w-12 h-12 md:w-16 md:h-16 rounded-2xl flex items-center justify-center ${isAdmin ? 'bg-yellow-400 text-slate-900 shadow-lg' : 'bg-slate-100 text-slate-400'}`}>
          {isAdmin ? (isEditing ? <Save onClick={handleSave} /> : <Edit3 />) : <Lock />}
        </button>
      </div>

      {/* Main Canvas Area */}
      <div className="flex-1 flex flex-col relative overflow-hidden">
        <header className="p-6 md:p-10 flex justify-between items-center z-20">
            <div className="bg-white/80 backdrop-blur-md px-6 py-3 rounded-full shadow-lg border border-white flex items-center gap-4">
                <span className="font-black text-indigo-600">PAGE {currentPage + 1}/10</span>
                <div className="h-4 w-[1px] bg-slate-200"></div>
                <h2 className="font-bold text-slate-800">{pages[currentPage].title}</h2>
            </div>
            <div className="flex gap-4">
                <button onClick={() => setCurrentPage(p => Math.max(0, p - 1))} className="bg-white p-4 rounded-full shadow-lg text-slate-400 hover:text-indigo-600 transition-colors"><ChevronLeft/></button>
                <button onClick={() => setCurrentPage(p => Math.min(pages.length - 1, p + 1))} className="bg-white p-4 rounded-full shadow-lg text-slate-400 hover:text-indigo-600 transition-colors"><ChevronRight/></button>
            </div>
        </header>

        <main className="flex-1 px-6 pb-10 md:px-12 md:pb-12 flex justify-center items-start overflow-hidden">
            <div className="w-full max-w-5xl h-full aspect-[1/1.414] bg-gradient-to-br from-indigo-500 via-purple-500 to-pink-500 rounded-[3rem] md:rounded-[4rem] p-8 md:p-16 border-[12px] md:border-[20px] border-white shadow-2xl relative overflow-hidden transition-all duration-700">
                <div className="h-full relative z-10 overflow-y-auto no-scrollbar">
                    {renderPage()}
                </div>
            </div>
        </main>

        {isEditing && (
            <div className="fixed bottom-10 right-10 z-50 animate-bounce">
                <button onClick={handleSave} className="bg-emerald-500 text-white px-8 py-4 rounded-2xl shadow-2xl flex items-center gap-3 font-bold text-lg border-4 border-white">
                    <Save /> บันทึกข้อมูลทั้งหมด
                </button>
            </div>
        )}
      </div>

      {/* Password Modal */}
      {showAuth && (
        <div className="fixed inset-0 z-[60] flex items-center justify-center bg-slate-900/60 backdrop-blur-sm">
            <div className="bg-white p-8 rounded-[2rem] shadow-2xl w-full max-w-sm text-center relative">
                <button onClick={() => setShowAuth(false)} className="absolute top-4 right-4 text-slate-400"><X/></button>
                <div className="bg-indigo-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4"><Lock className="text-indigo-600" size={32}/></div>
                <h3 className="text-xl font-bold mb-6 font-kanit text-slate-800">ยืนยันตัวตนเพื่อแก้ไข</h3>
                <form onSubmit={(e) => {
                    e.preventDefault();
                    if (e.target.pass.value === '1234') { setIsAdmin(true); setShowAuth(false); setIsEditing(true); }
                    else { alert("รหัสผ่านไม่ถูกต้อง"); e.target.pass.value = ''; }
                }}>
                    <input name="pass" type="password" placeholder="รหัสผ่าน (1234)" className="w-full text-center text-xl p-3 border-2 rounded-xl mb-4 outline-none focus:border-indigo-500" autoFocus />
                    <button type="submit" className="w-full bg-indigo-600 text-white py-3 rounded-xl font-bold hover:bg-indigo-700">ตกลง</button>
                </form>
            </div>
        </div>
      )}

      <style>
        {`
          @import url('https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;700;800&family=Kanit:wght@400;700;900&display=swap');
          body { font-family: 'Sarabun', sans-serif; }
          .font-kanit { font-family: 'Kanit', sans-serif; }
          .no-scrollbar::-webkit-scrollbar { display: none; }
          .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        `}
      </style>
    </div>
  );
}
